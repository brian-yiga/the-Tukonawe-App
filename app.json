{
  "expo": {
    "name": "TukonaweApp",
    "slug": "TukonaweApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-square.png",
    "scheme": "tukonaweapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon-square.png",
        "backgroundImage": "./assets/images/icon-square.png",
        "monochromeImage": "./assets/images/icon-square.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-nobg.png",
      "manifest": {
        "name": "TukonaweApp",
        "short_name": "Tukonawe",
        "description": "Your mental health companion.",
        "background_color": "#E6F4FE",
        "theme_color": "#588C79",
        "display": "standalone",
        "orientation": "portrait",
        "start_url": ".",
        "scope": "/"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
